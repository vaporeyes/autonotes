# ABOUTME: Environment variable template for the Autonotes orchestrator.
# ABOUTME: Copy to .env and fill in your values before running docker compose up.

# Obsidian Local REST API connection
OBSIDIAN_API_URL=https://host.docker.internal:27124
OBSIDIAN_API_KEY=your-obsidian-rest-api-key

# LLM provider configuration (claude or openai)
LLM_PROVIDER=claude
LLM_API_KEY=your-anthropic-or-openai-key

# PostgreSQL
POSTGRES_USER=autonotes
POSTGRES_PASSWORD=autonotes
POSTGRES_DB=autonotes
DATABASE_URL=postgresql+asyncpg://autonotes:autonotes@postgres:5432/autonotes

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Operation log retention (days)
LOG_RETENTION_DAYS=90
